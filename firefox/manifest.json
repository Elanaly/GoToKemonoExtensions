{
    "manifest_version": 2,
    "name": "GoToKemono",
    "description": "fantia.jpのファンクラブページで右クリックしてkemono.crに移動できます",
    "version": "1.0.0",
    "permissions": [
        "contextMenus",
        "tabs",
        "https://fantia.jp/fanclubs/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "gotokemono@extension",
            "strict_min_version": "57.0"
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    }
}