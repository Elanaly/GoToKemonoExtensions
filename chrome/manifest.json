{
    "manifest_version": 3,
    "name": "GoToKemono",
    "description": "fantia.jpやfanbox.ccのページで右クリックしてkemono.crに移動できます",
    "version": "1.1.0",
    "permissions": [
        "contextMenus",
        "tabs"
    ],
    "host_permissions": [
        "https://fantia.jp/fanclubs/*",
        "https://*.fanbox.cc/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.fanbox.cc/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}